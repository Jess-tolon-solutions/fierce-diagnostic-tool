# =============================================================================
# HubSpot Forms API — REQUIRED for production
# =============================================================================
# When BOTH are set, every diagnostic submission creates/updates a Contact in
# HubSpot via the Forms API. If either is blank, the integration no-ops and
# submissions just log to the server console.
#
# See HUBSPOT_SETUP.md for the exact custom properties and form to create.

# 7- or 8-digit HubSpot Portal ID. Visible in HubSpot URL or Settings → Account
HUBSPOT_PORTAL_ID=

# GUID of the form to submit to. After creating the "Fierce Diagnostic
# Submission" form in HubSpot, copy the form GUID from the form's embed code
# or URL.
HUBSPOT_FORM_GUID=

# =============================================================================
# Optional: real-time ops notification (Slack incoming webhook, etc.)
# =============================================================================
# If set, a copy of the formatted briefing posts to this URL on every
# submission. Best-effort — failure here does NOT fail the submission.
SUBMISSION_WEBHOOK_URL=
